# ========================
# Claude Code
# ========================

# API key authentication (recommended for Docker)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Bearer token for LLM gateway/proxy setups (alternative to API key)
# ANTHROPIC_AUTH_TOKEN=

# Override Claude model (default: latest)
# ANTHROPIC_MODEL=claude-opus-4-6

# Cloud provider backends (set ONE if using managed infrastructure)
# CLAUDE_CODE_USE_BEDROCK=true
# CLAUDE_CODE_USE_VERTEX=true

# ========================
# Blockchain
# ========================

# Default Ethereum RPC endpoint
ETH_RPC_URL=

# Certora Prover API key (formal verification)
CERTORAKEY=

# ========================
# Chainbox
# ========================

# Override image name (default: 7feilee/chainbox)
# CHAINBOX_IMAGE=yourusername/chainbox

# Container username (default: agent) — must match USERNAME build arg
# CHAINBOX_USER=agent

# Project directory for docker-compose (default: current directory)
# PROJECT_DIR=./my-project
